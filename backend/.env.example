PORT=4000
PAYMENT_LINK_BASE=http://localhost:3000

# Supabase (service role key is required for server-side inserts)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# pg connection pool — use the Transaction Pooler URI from Supabase dashboard:
# Project Settings → Database → Connection string → Transaction (port 6543) → URI
# Example: postgresql://postgres.xxxx:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_transaction_pooler_uri

# Redis connection used for distributed rate limiting across app instances
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Stellar config
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=

# SEP-0010 Web Authentication
# Generate with: node -e "console.log(require('stellar-sdk').Keypair.random().secret())"
SEP10_SERVER_SIGNING_KEY=your_secret_key_here

# Optional asset issuers
USDC_ISSUER=your_usdc_issuer

# Webhook signing – shared secret used to produce Stellar-Signature: sha256=<hmac>
# Generate a strong random value, e.g.: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret

# CORS configuration – comma-separated list of allowed origins
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Create-payment endpoint rate limit configuration
# Defaults: 50 requests per 60 seconds per API key
CREATE_PAYMENT_RATE_LIMIT_MAX=50
CREATE_PAYMENT_RATE_LIMIT_WINDOW_MS=60000
