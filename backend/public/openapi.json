          },
          "404": {
            "description": "Payment not found"
          }
        }
      }
    },
    "/api/payments/{id}/refund/confirm": {
      "post": {
        "summary": "Confirm a refund transaction has been submitted",
        "tags": [
          "Payments"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Payment ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "tx_hash"
                ],
                "properties": {
                  "tx_hash": {
                    "type": "string",
                    "description": "Submitted refund transaction hash"
                  }
                }
              }
